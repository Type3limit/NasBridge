SERVER_BASE_URL=http://localhost:8080
REGISTRATION_KEY=replace-client-key
JWT_SECRET=replace-this-with-the-same-secret-as-server
CLIENT_NAME=HomeStorageNode-1
STORAGE_ROOT=G:/NAS_DATA
YT_DLP_PATH=yt-dlp
BOT_BILIBILI_DOWNLOAD_BACKEND=playwright
BOT_BILIBILI_IMPORT_DIR=downloads/bilibili
# Optional: use cookies for members-only or restricted Bilibili content
BOT_BILIBILI_COOKIE_FILE=
# Optional: leave empty to use Playwright's bundled browser. Set only when you want a custom Chromium executable.
BOT_BILIBILI_PLAYWRIGHT_EXECUTABLE_PATH=
BOT_BILIBILI_PLAYWRIGHT_HEADLESS=1
BOT_BILIBILI_PLAYWRIGHT_PROXY=
# Internal bot runtime data. This directory is excluded from the library index.
BOT_APP_DATA_DIR_NAME=.nas-bot
# AI provider: optional explicit value, supports copilot / ark / openai.
AI_PROVIDER=

# Copilot API Proxy (OpenAI-compatible).
# Example: npx copilot-api@latest start --port 4141
# Then set COPILOT_API_BASE_URL=http://127.0.0.1:4141/v1 and choose a model from GET /v1/models.
# copilot-api usually accepts any bearer token for the OpenAI-compatible endpoint; default fallback is "dummy".
COPILOT_API_BASE_URL=
COPILOT_API_KEY=
COPILOT_AUTH_TOKEN=
COPILOT_MODEL=
# Optional: if the selected Copilot model also supports vision, you can set it explicitly.
COPILOT_MULTIMODAL_MODEL=
COPILOT_DUMMY_API_KEY=dummy

# Volcengine Ark / generic OpenAI-compatible provider
ARK_BASE_URL=
ARK_API_KEY=
ARK_MODEL=
# Optional: dedicate a multimodal model for image analysis.
ARK_MULTIMODAL_MODEL=
# Optional fallback when your provider uses endpoint id semantics.
ARK_ENDPOINT_ID=
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_MULTIMODAL_MODEL=

# STUN – same as web/.env VITE_STUN_URL
STUN_URL=stun:stun.l.google.com:19302

# TURN – must match web/.env VITE_TURN_* and deploy/turn/.env
# Required for LAN cross-machine access (see web/.env.example for explanation)
TURN_URL=turn:192.168.x.x:3478
TURN_USERNAME=nasuser
TURN_CREDENTIAL=naspass123
ICE_CANDIDATE_POOL_SIZE=2
# Optional: delay signaling of direct-NAT candidates slightly, and relay longer.
P2P_SRFLX_DELAY_MS=300
P2P_RELAY_DELAY_MS=1800
# Optional compatibility fallback. When the two values above are unset, this applies to both.
P2P_HOST_FIRST_DELAY_MS=0

ENABLE_TRANSCODE=1
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
TRANSCODE_VIDEO_CODEC=auto
TRANSCODE_PREFER_GPU=1
ALLOW_GPU_HLS_ENCODING=1
HLS_VIDEO_CODEC=auto
HLS_NVENC_PRESET=p2
HLS_NVENC_USE_CUDA_PIPELINE=0
DISABLED_ENCODER_COOLDOWN_MS=900000

# HLS / GPU quick profiles
# NVIDIA:
# HLS_VIDEO_CODEC=h264_nvenc
# HLS_NVENC_PRESET=p1
# HLS_NVENC_USE_CUDA_PIPELINE=0
# TRANSCODE_VIDEO_CODEC=h264_nvenc
# TRANSCODE_PREFER_GPU=1
#
# Intel Quick Sync:
# HLS_VIDEO_CODEC=h264_qsv
# TRANSCODE_VIDEO_CODEC=h264_qsv
# TRANSCODE_PREFER_GPU=1
#
# AMD AMF:
# HLS_VIDEO_CODEC=h264_amf
# TRANSCODE_VIDEO_CODEC=h264_amf
# TRANSCODE_PREFER_GPU=1

# optional: cached client JWT after first register
CLIENT_TOKEN=

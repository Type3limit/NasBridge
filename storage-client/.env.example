# ========== 基础连接（必填） ==========
SERVER_BASE_URL=http://localhost:8080
REGISTRATION_KEY=replace-client-key
JWT_SECRET=replace-this-with-the-same-secret-as-server
STORAGE_ROOT=G:/NAS_DATA

# 当前存储节点名称；留默认即可。
CLIENT_NAME=HomeStorageNode-1
# 首次注册成功后会自动写回，通常无需手填。
CLIENT_TOKEN=

# ========== 本地工具与运行目录 ==========
YT_DLP_PATH=yt-dlp
# Bot 运行时数据目录，会自动从媒体库索引中排除。
BOT_APP_DATA_DIR_NAME=.nas-bot

# ========== Playwright 通用配置 ==========
# bilibili 下载和 AI 联网搜索共用这一组配置。
# 留空时优先使用 Playwright 自带浏览器；若本机没装，可指定系统 Chrome / Edge 路径。
PLAYWRIGHT_EXECUTABLE_PATH=
# 1 为无头模式，0 为显示浏览器窗口，排查页面问题时可改成 0。
PLAYWRIGHT_HEADLESS=1
# 需要走代理时填写，例如 http://127.0.0.1:7890
PLAYWRIGHT_PROXY=

# ========== AI 提供商 ==========
# 可选：copilot / ark / openai。留空时会根据已填写的变量自动判断。
AI_PROVIDER=

# Copilot 兼容代理配置
# 示例：npx copilot-api@latest start --port 4141
COPILOT_API_BASE_URL=
COPILOT_API_KEY=
COPILOT_AUTH_TOKEN=
COPILOT_MODEL=
# 可选：单独指定看图模型；不填时会回退到文本模型。
COPILOT_MULTIMODAL_MODEL=
# copilot-api 通常允许任意 bearer token，不要求真实 key 时可保留默认值。
COPILOT_DUMMY_API_KEY=dummy

# Ark 配置
ARK_BASE_URL=
ARK_API_KEY=
ARK_MODEL=
# 可选：单独指定多模态模型。
ARK_MULTIMODAL_MODEL=
# 可选：某些兼容服务使用 endpoint id 作为模型标识。
ARK_ENDPOINT_ID=

# 通用 OpenAI 兼容接口配置
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_MULTIMODAL_MODEL=

# ========== AI 联网搜索 ==========
# 搜索提供方：
# auto：默认，优先 Search API（已配置时），然后内置引擎
# builtin：强制使用内置网页搜索
# metaso：通过 Playwright 模拟秘塔网页搜索，不依赖 API
BOT_WEB_SEARCH_PROVIDER=auto
# auto：已配置 Search API 时优先 API，否则先 fetch，失败再试 playwright
# api：强制结构化搜索 API
# fetch：强制 HTTP 抓取搜索页
# playwright：优先浏览器抓取，遇到挑战页时会自动回退到更稳的抓取方式
BOT_WEB_SEARCH_BACKEND=auto
# 使用 metaso provider 时，搜索阶段固定走浏览器模拟；这里的 backend 主要影响普通网页抓取与结果页摘要抓取。
# 可选：结构化搜索 API，目前支持 brave / serpapi
BOT_WEB_SEARCH_API_BACKEND=serpapi
BOT_WEB_SEARCH_API_KEY=
# 可选：覆盖默认 API 地址
BOT_WEB_SEARCH_API_BASE_URL=
# 可选：自定义搜索端点，多个用逗号分隔；默认依次尝试 DuckDuckGo HTML 和 Bing
BOT_WEB_SEARCH_ENDPOINTS=

# ========== bilibili Bot ==========
# playright：优先浏览器提取；playwright-only：只允许浏览器方案；yt-dlp：只走 yt-dlp
BOT_BILIBILI_DOWNLOAD_BACKEND=playwright
BOT_BILIBILI_IMPORT_DIR=downloads/bilibili
# 可选：会员内容或受限视频可填写 cookies 文件路径
BOT_BILIBILI_COOKIE_FILE=
# 可选：直接通过环境变量注入登录态 Cookie；B 站 API/WBI 与下载链路都会复用
BOT_BILIBILI_COOKIE_HEADER=
BOT_BILIBILI_SESSDATA=
BOT_BILIBILI_BUVID3=
BOT_BILIBILI_DEDEUSERID=
BOT_BILIBILI_BILI_JCT=

# ========== WebRTC / P2P ==========
# 与 web/.env 中的 STUN/TURN 配置保持一致。
STUN_URL=stun:stun.l.google.com:19302
TURN_URL=turn:192.168.x.x:3478
TURN_USERNAME=nasuser
TURN_CREDENTIAL=naspass123
ICE_CANDIDATE_POOL_SIZE=2
# 可选：适当延迟不同候选类型的发送顺序，改善弱网连通性。
P2P_SRFLX_DELAY_MS=300
P2P_RELAY_DELAY_MS=1800
# 兼容旧逻辑；如果上面两个都没填，则使用这个统一延迟。
P2P_HOST_FIRST_DELAY_MS=0

# ========== 转码与 HLS ==========
ENABLE_TRANSCODE=1
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
# auto 会优先尝试 GPU，失败再回退到 CPU。
TRANSCODE_VIDEO_CODEC=auto
TRANSCODE_PREFER_GPU=1
ALLOW_GPU_HLS_ENCODING=1
HLS_VIDEO_CODEC=auto
HLS_NVENC_PRESET=p2
HLS_NVENC_USE_CUDA_PIPELINE=0
# GPU 编码器失败后的冷却时间，默认 15 分钟。
DISABLED_ENCODER_COOLDOWN_MS=900000

# GPU 示例：按需取消注释后替换默认值
# NVIDIA
# HLS_VIDEO_CODEC=h264_nvenc
# HLS_NVENC_PRESET=p1
# HLS_NVENC_USE_CUDA_PIPELINE=0
# TRANSCODE_VIDEO_CODEC=h264_nvenc
# TRANSCODE_PREFER_GPU=1
#
# Intel Quick Sync
# HLS_VIDEO_CODEC=h264_qsv
# TRANSCODE_VIDEO_CODEC=h264_qsv
# TRANSCODE_PREFER_GPU=1
#
# AMD AMF
# HLS_VIDEO_CODEC=h264_amf
# TRANSCODE_VIDEO_CODEC=h264_amf
# TRANSCODE_PREFER_GPU=1

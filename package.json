{
  "name": "nas-bridge",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "server",
    "web",
    "storage-client"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:web dev:client",
    "dev:server": "npm run dev -w server",
    "dev:web": "npm run dev -w web",
    "dev:client": "npm run dev -w storage-client",
    "build": "npm run build -w web",
    "start": "npm run start -w server",
    "deploy:start": "powershell -ExecutionPolicy Bypass -File scripts/deploy-and-start.ps1",
    "deploy:start:linux": "bash ./scripts/deploy-and-start.sh",
    "deploy:stop:linux": "bash ./scripts/stop-services.sh"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}

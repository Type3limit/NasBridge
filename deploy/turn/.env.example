# For LAN-only deployment: set this to the server machine's LAN IP (e.g. 192.168.6.143)
# For internet-accessible deployment: set this to the server's public IP
TURN_EXTERNAL_IP=192.168.x.x

# The realm is an arbitrary identifier shown in TURN auth challenges
TURN_REALM=nas-bridge.local

# Credentials – must match VITE_TURN_USERNAME/CREDENTIAL in web/.env
# and TURN_USERNAME/CREDENTIAL in storage-client/.env
TURN_USERNAME=nasuser
TURN_PASSWORD=naspass123

# UDP/TCP port coturn listens on (relay ports will use 49152-49200)
TURN_PORT=3478

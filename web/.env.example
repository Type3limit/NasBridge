VITE_SERVER_BASE_URL=http://localhost:9000
VITE_DEV_PROXY_TARGET=http://127.0.0.1:9000
VITE_DEV_WS_PROXY_TARGET=ws://127.0.0.1:9000

# STUN – used first (free, no relay).  Google's public server works for internet access.
# For LAN-only: can leave as-is or use a local STUN.
VITE_STUN_URL=stun:stun.l.google.com:19302

# TURN – required for LAN cross-machine access.
# Chrome hides local IPs behind mDNS (.local) hostnames which Node.js cannot resolve,
# so host-path ICE always fails cross-machine.  TURN relays through the server itself
# and bypasses both mDNS and NAT hairpinning issues.
#
# Set all three to the values matching deploy/turn/.env, then start coturn:
#   cd deploy/turn && cp .env.example .env  (edit TURN_EXTERNAL_IP to your LAN IP)
#   docker compose up -d
VITE_TURN_URL=turn:192.168.x.x:3478
VITE_TURN_USERNAME=nasuser
VITE_TURN_CREDENTIAL=naspass123

# WebRTC diagnostics / experiments
# Pre-gather a small candidate pool before the first offer.
VITE_ICE_CANDIDATE_POOL_SIZE=2
# Optional: delay signaling of direct-NAT candidates slightly, and relay longer.
VITE_P2P_SRFLX_DELAY_MS=300
VITE_P2P_RELAY_DELAY_MS=1800
# Optional compatibility fallback. When the two values above are unset, this applies to both.
VITE_P2P_HOST_FIRST_DELAY_MS=0
# Optional: if the selected pair is relay and the peer is still idle, try one ICE restart later.
VITE_P2P_RELAY_UPGRADE_DELAY_MS=5000
